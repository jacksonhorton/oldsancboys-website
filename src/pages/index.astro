---
import PageLayout from "../layouts/PageLayout.astro";
import Gallery from "../components/Gallery.astro";
import type { ImageMetadata } from "astro";

import { Blockquote, Heading, Hr, Carousel, P } from "flowbite-svelte";
import { QuoteSolid } from "flowbite-svelte-icons";

import { Image, getImage, imageConfig } from "astro:assets";
import pyrImage from "../images/OSB-pyr-trans-custom.png";

// import camp24Image from "../images/carousel/camp24.jpg";
// import fofClinton1Image from "../images/carousel/fof-clinton1.jpg";
// import fofClinton2Image from "../images/carousel/fof-clinton2.jpg";
// let carouselImages: { image: ImageMetadata; name?: string }[] = [
// 	{ image: fofClinton2Image, name: "Fields of Faith 2024 - Clinton, KY"},
// 	{ image: camp24Image, name: "Central Baptist Summer Camp 2024" },
// 	{ image: fofClinton1Image, name: "Fields of Faith 2024 - Clinton, KY"}
// ];

const pageTitle = "";
---

<PageLayout
	title={pageTitle}
	description="Home of the Old Sanc Boys! Check out some pics, music, and how to get in contact with us."
>
	<div class="w-full relative">
		<Image
			class="max-h-svh w-auto max-w-sm md:max-w-2xl lg:max-w-4xl mx-auto"
			src={pyrImage}
			width={pyrImage.width / 2}
			height={pyrImage.height / 2}
			alt="Picture of the old sanc boys with their instruments looking really, really cool."
			loading="lazy"
		/>
		<div
			class="-translate-x-1/2 -translate-y-1/2 absolute top-2/3 left-1/2 w-full text-center"
		>
			<Heading
				tag="h1"
				class="mb-4 text-white spac"
				customSize="text-4xl md:text-8xl font-extrabold tracking-widest"
			>
				<span style="text-shadow: 0 0 10px rgb(149, 148, 166);">
					Old Sanc Boys
				</span>
			</Heading>
		</div>
	</div>

	<div class="flex items-center justify-center content-center w-full mt-14">
		<figure class="mt-8 mx-auto max-w-screen-md text-center">
			<QuoteSolid
				class="mx-auto mb-3 w-12 h-12 text-gray-400 dark:text-gray-600"
			/>
			<Blockquote class="tracking-wide" alignment="center" size="2xl">
				"The joke gone too far."
			</Blockquote>
			<figcaption
				class="flex justify-center items-center mt-6 space-x-3 rtl:space-x-reverse"
			>
				<div
					class="flex items-center divide-x-2 rtl:divide-x-reverse divide-gray-500 dark:divide-gray-700"
				>
					<cite
						class="tracking-wider pe-3 font-medium text-gray-900 dark:text-white"
						>Josh Scott</cite
					>
				</div>
			</figcaption>
		</figure>
	</div>

	<Hr hrClass="w-64 h-1 mx-auto my-14 rounded" />
	<Gallery />
	<Hr hrClass="w-64 h-1 mx-auto my-14 rounded" />

	<div class="max-w-[90%] md:w-3/5 mx-auto">
		<Heading
			tag="h1"
			class="mb-4 text-green-600 w-full"
			customSize="text-4xl md:text-5xl font-extrabold tracking-widest"
		>
			<span style="text-shadow: 2px 2px 20px rgb(216, 217, 216);"
				>Who Are We?</span
			>
		</Heading>
		<P weight="light">
			Josh, Charles, and Jackson had all started to serve at church in
			various worship settings, but never all together. Until they were
			asked to come together to lead in the “old sanc” <span
				style="font-style: italic;"
				class="text-gray-400">(sanctuary)</span
			>
			for the kids ministry. And it was a blast. From then on, they dubbed themselves
			the Old Sanc Boys as an homage to their first time playing together <span
				style="font-style: italic;"
				class="text-gray-400"
				>(not just something weird or the “old saint boys”)</span
			>. They still enjoy any opportunity they get to worship together
			privately, at church, campfires, or at events.
			<br />
			<br />
			If you have an event or otherwise and need a band, let us know! We'd love
			to play for you! <span
				class="text-primary-600 dark:text-primary-500 font-bold underline"
				><a href="/contact">Contact us</a></span
			>
		</P>

		<div class="py-7"></div>
		<!-- <div class="flex justify-center mt-10">
		<div class="mx-5 w-screen lg:max-w-2xl md:max-w-xl max-w-xl">
			<Carousel client:load images={carouselImages} duration={4500} />
		</div>
	</div> -->

		<!-- <div class="w-full flex items-center content-center justify-center">
		<Timeline class="m-auto w-10/12 max-w-lg">
			<TimelineItem
				title="Application UI code in Tailwind CSS"
				date="February 2022"
			>
				<p
					class="mb-4 text-base font-normal text-gray-500 dark:text-gray-400"
				>
					Get access to over 20+ pages including a dashboard layout,
					charts, kanban board, calendar, and pre-order E-commerce &
					Marketing pages.
				</p>
			</TimelineItem>
		</Timeline>
		<div></div>
	</div> -->
	</div>
</PageLayout>
